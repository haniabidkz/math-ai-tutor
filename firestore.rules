rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function verified() { return signedIn() && request.auth.token.email_verified == true; }
    function superAdmin() { return verified() && request.auth.token.super_admin == true; }
    function owner(uid) { return verified() && request.auth.uid == uid; }
    function teacher() { return verified() && exists(/databases/$(database)/documents/teachers/$(request.auth.uid)); }
    function parent() { return verified() && exists(/databases/$(database)/documents/parents/$(request.auth.uid)); }
    function parentOf(uid) {
      return parent()
        && get(/databases/$(database)/documents/students/$(uid)).data.parentEmail == request.auth.token.email;
    }

    match /students/{uid} {
      allow read: if owner(uid) || superAdmin() || teacher()
        || (parent() && resource.data.parentEmail == request.auth.token.email);
      allow update: if owner(uid) || superAdmin();
      allow create: if signedIn() && request.auth.uid == uid;
      allow delete: if superAdmin();
      match /{subcollection}/{document=**} {
        allow read: if owner(uid) || superAdmin() || teacher() || parentOf(uid);
        allow write: if superAdmin();
      }
    }
    match /parents/{uid} {
      allow read, update: if owner(uid) || superAdmin();
      allow create: if signedIn() && request.auth.uid == uid;
      allow delete: if superAdmin();
    }
    match /teachers/{uid} {
      allow read: if owner(uid) || superAdmin();
      allow create: if signedIn() && request.auth.uid == uid;
      allow update, delete: if superAdmin();
    }
    match /admins/{uid} { allow read: if owner(uid) && superAdmin(); allow write: if false; }
    match /microConcepts/{id} { allow read: if verified(); allow write: if superAdmin(); }
    match /questions/{id} { allow read: if verified() && resource.data.status == 'published'; allow write: if superAdmin(); }
    match /assessmentConfigs/{id} { allow read: if verified(); allow write: if superAdmin(); }
    match /auditLogs/{id} { allow read: if superAdmin(); allow write: if false; }
  }
}
