{
    "name": "smart-math-tutor",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint . --max-warnings=0",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:rules": "firebase emulators:exec --only firestore \"vitest run tests/firestore-rules.test.ts\"",
        "test:e2e": "playwright test",
        "content:validate": "tsx scripts/validate-content.ts",
        "seed": "tsx scripts/seed.ts",
        "seed:content": "tsx --env-file=.env.local scripts/seed-content.ts",
        "migrate:students": "tsx --env-file=.env.local scripts/migrate-students.ts",
        "admin:grant": "tsx --env-file=.env.local scripts/grant-super-admin.ts",
        "firebase:deploy": "tsx --env-file=.env.local scripts/deploy-firebase-resources.ts",
        "vercel:env": "tsx --env-file=.env.local scripts/sync-vercel-env.ts"
    },
    "dependencies": {
        "@types/canvas-confetti": "^1.9.0",
        "canvas-confetti": "^1.9.4",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "dotenv": "^17.3.1",
        "firebase": "^12.8.0",
        "firebase-admin": "13.10.0",
        "framer-motion": "^12.34.0",
        "lucide-react": "^0.563.0",
        "next": "^15.5.18",
        "openai": "^4.80.0",
        "radix-ui": "^1.4.3",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-markdown": "^10.1.0",
        "tailwind-merge": "^3.4.0",
        "tailwindcss-animate": "^1.0.7",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@firebase/rules-unit-testing": "^5.0.1",
        "@playwright/test": "^1.61.1",
        "@tailwindcss/postcss": "^4.0.0",
        "@testing-library/jest-dom": "^7.0.0",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^22.0.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^6.0.3",
        "@vitest/coverage-v8": "^4.1.10",
        "eslint": "^9.0.0",
        "eslint-config-next": "^15.1.0",
        "firebase-tools": "^15.24.0",
        "jsdom": "^29.1.1",
        "postcss": "^8.5.0",
        "tailwindcss": "^4.0.0",
        "tsx": "^4.23.1",
        "typescript": "^5.7.0",
        "vercel": "^56.4.0",
        "vitest": "^4.1.10"
    }
}
